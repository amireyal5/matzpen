
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "פרופיל משתמש הכולל שם, מגדר, מועדפים, כרטיסיות שבוצעו ותשתית התראות.",
      "properties": {
        "id": {
          "type": "string",
          "description": "מזהה המשתמש (UID)."
        },
        "name": {
          "type": "string",
          "description": "שם המשתמש."
        },
        "gender": {
          "type": "string",
          "description": "מגדר המשתמש (m/f).",
          "enum": ["m", "f"]
        },
        "email": {
          "type": "string",
          "description": "כתובת האימייל של המשתמש."
        },
        "favorites": {
          "type": "array",
          "items": { "type": "string" },
          "description": "רשימת מזהי כרטיסיות מועדפות (catKey:index)."
        },
        "completed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "רשימת מזהי כרטיסיות שבוצעו (catKey:index)."
        },
        "fcmToken": {
          "type": "string",
          "description": "מפתח זיהוי להתראות פוש."
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "האם המשתמש אישר קבלת התראות."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "gender"]
    },
    "ThoughtJournalEntry": {
      "title": "ThoughtJournalEntry",
      "type": "object",
      "description": "תיעוד של תרגול יומן מחשבות במודל אפר\"ת כולל ניתוח AI, מקושר למשתמש.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "מזהה המשתמש שכתב את היומן." },
        "event": { "type": "string" },
        "interpretation": { "type": "string" },
        "feeling": { "type": "string" },
        "reaction": { "type": "string" },
        "analysis": {
          "type": "object",
          "properties": {
            "distortions": { "type": "array", "items": { "type": "string" } },
            "healthyPerspective": { "type": "string" },
            "summary": { "type": "string" },
            "isCrisis": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "event", "interpretation", "feeling", "reaction", "createdAt"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "type": "object",
      "description": "התראה בתוך האפליקציה למשתמש.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["system", "reminder", "insight"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "body", "read", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "userProfiles": {
      "path": "/userProfiles/{userId}",
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "אחסון פרופילי משתמשים. גישה מותרת רק לבעל הפרופיל."
    },
    "thoughtJournals": {
      "path": "/thoughtJournals/{journalId}",
      "schema": {
        "$ref": "#/backend/entities/ThoughtJournalEntry"
      },
      "description": "אחסון יומני מחשבות באוסף נפרד עם קישור ל-userId."
    },
    "notifications": {
      "path": "/notifications/{notificationId}",
      "schema": {
        "$ref": "#/backend/entities/AppNotification"
      },
      "description": "אחסון התראות למשתמשים."
    }
  }
}
