
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "פרופיל משתמש הכולל שם ומגדר לצורך פנייה מותאמת אישית.",
      "properties": {
        "id": {
          "type": "string",
          "description": "מזהה המשתמש (UID)."
        },
        "name": {
          "type": "string",
          "description": "שם המשתמש."
        },
        "gender": {
          "type": "string",
          "description": "מגדר המשתמש (m/f).",
          "enum": ["m", "f"]
        },
        "email": {
          "type": "string",
          "description": "כתובת האימייל של המשתמש."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "gender"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "userProfiles": {
      "path": "/userProfiles/{userId}",
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "אחסון פרופילי משתמשים. גישה מותרת רק לבעל הפרופיל."
    }
  }
}
