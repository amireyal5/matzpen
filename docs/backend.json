
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "פרופיל משתמש הכולל שם, מגדר, מועדפים וכרטיסיות שבוצעו.",
      "properties": {
        "id": {
          "type": "string",
          "description": "מזהה המשתמש (UID)."
        },
        "name": {
          "type": "string",
          "description": "שם המשתמש."
        },
        "gender": {
          "type": "string",
          "description": "מגדר המשתמש (m/f).",
          "enum": ["m", "f"]
        },
        "email": {
          "type": "string",
          "description": "כתובת האימייל של המשתמש."
        },
        "favorites": {
          "type": "array",
          "items": { "type": "string" },
          "description": "רשימת מזהי כרטיסיות מועדפות (catKey:index)."
        },
        "completed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "רשימת מזהי כרטיסיות שבוצעו (catKey:index)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "gender"]
    },
    "ThoughtJournalEntry": {
      "title": "ThoughtJournalEntry",
      "type": "object",
      "description": "תיעוד של תרגול יומן מחשבות במודל אפר\"ת כולל ניתוח AI.",
      "properties": {
        "id": { "type": "string" },
        "event": { "type": "string" },
        "interpretation": { "type": "string" },
        "feeling": { "type": "string" },
        "reaction": { "type": "string" },
        "analysis": {
          "type": "object",
          "properties": {
            "distortions": { "type": "array", "items": { "type": "string" } },
            "healthyPerspective": { "type": "string" },
            "summary": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["event", "interpretation", "feeling", "reaction", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "userProfiles": {
      "path": "/userProfiles/{userId}",
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "אחסון פרופילי משתמשים. גישה מותרת רק לבעל הפרופיל."
    },
    "thoughtJournals": {
      "path": "/userProfiles/{userId}/journals/{journalId}",
      "schema": {
        "$ref": "#/backend/entities/ThoughtJournalEntry"
      },
      "description": "היסטוריית יומני מחשבות של המשתמש."
    }
  }
}
