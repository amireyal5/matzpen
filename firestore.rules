
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- פונקציות עזר לאבטחה ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- חוקי גישה לאוספים ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    match /thoughtJournals/{journalId} {
      // קריאה ומחיקה רק לבעל היומן
      allow get, list, delete: if isDocOwner();
      // יצירה רק אם ה-userId בנתונים תואם למשתמש המחובר
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // עדכון רק לבעל היומן ובתנאי שלא משנים את הבעלות
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /practices/{practiceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /practiceSteps/{practiceStepId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}
